{
  "name": "@getmodus/sdk",
  "version": "0.0.0",
  "description": "Official TypeScript client for Modus — your organization's context layer for AI",
  "type": "module",
  "license": "MIT",
  "keywords": ["modus", "ai", "data", "sdk"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/modus-data/modus-sdk-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/modus-data/modus-sdk-typescript/issues"
  },
  "homepage": "https://github.com/modus-data/modus-sdk-typescript#readme",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./management": {
      "import": {
        "types": "./dist/management/index.d.ts",
        "default": "./dist/management/index.js"
      },
      "require": {
        "types": "./dist/management/index.d.cts",
        "default": "./dist/management/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^3.2.6"
  }
}
